{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set: scoped fs to ~/.claude, ~/.codex, ~/.cursor + dialogs + shell open",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.claude" },
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.codex" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.cursor" },
        { "path": "$HOME/.cursor/**" },
        { "path": "$HOME/.agents" },
        { "path": "$HOME/.agents/**" },
        { "path": "$HOME/.clinerules" },
        { "path": "$HOME/.clinerules/**" },
        { "path": "$HOME/Documents/Cline" },
        { "path": "$HOME/Documents/Cline/**" },
        { "path": "$HOME/Cline" },
        { "path": "$HOME/Cline/**" },
        { "path": "$HOME/.openclaw" },
        { "path": "$HOME/.openclaw/**" },
        { "path": "$HOME/.hermes" },
        { "path": "$HOME/.hermes/**" },
        { "path": "$HOME/**/.hermes" },
        { "path": "$HOME/**/.hermes/**" },
        { "path": "$HOME/**/hermes" },
        { "path": "$HOME/**/hermes/**" },
        { "path": "$HOME/**/.claude" },
        { "path": "$HOME/**/.claude/**" },
        { "path": "$HOME/**/.codex" },
        { "path": "$HOME/**/.codex/**" },
        { "path": "$HOME/**/.cursor" },
        { "path": "$HOME/**/.cursor/**" },
        { "path": "$HOME/**/.agents" },
        { "path": "$HOME/**/.agents/**" },
        { "path": "$HOME/**/.clinerules" },
        { "path": "$HOME/**/.clinerules/**" },
        { "path": "$HOME/**/skills" },
        { "path": "$HOME/**/skills/**" },
        { "path": "$HOME/**/skills-lock.json" },
        { "path": "$HOME/**/CLAUDE.md" },
        { "path": "$HOME/**/AGENTS.md" },
        { "path": "$HOME/**/.mcp.json" },
        { "path": "$HOME/**/skillsafe-backup" },
        { "path": "$HOME/**/skillsafe-backup/**" },
        { "path": "$HOME/**/scheduled-backup" },
        { "path": "$HOME/**/scheduled-backup/**" },
        { "path": "$HOME/**/LAST_BACKUP.json" },
        { "path": "$HOME/**/claude" },
        { "path": "$HOME/**/claude/**" },
        { "path": "$HOME/**/codex" },
        { "path": "$HOME/**/codex/**" },
        { "path": "$HOME/**/cursor" },
        { "path": "$HOME/**/cursor/**" },
        { "path": "$HOME/**/openclaw" },
        { "path": "$HOME/**/openclaw/**" },
        { "path": "$HOME/**/cline" },
        { "path": "$HOME/**/cline/**" },
        { "path": "$HOME/**/claude_backup" },
        { "path": "$HOME/**/claude_backup/**" },
        { "path": "$HOME/**/codex_backup" },
        { "path": "$HOME/**/codex_backup/**" },
        { "path": "$HOME/**/cursor_backup" },
        { "path": "$HOME/**/cursor_backup/**" },
        { "path": "$HOME/**/openclaw_backup" },
        { "path": "$HOME/**/openclaw_backup/**" },
        { "path": "$HOME/**/cline_backup" },
        { "path": "$HOME/**/cline_backup/**" },
        { "path": "$HOME/**/hermes_backup" },
        { "path": "$HOME/**/hermes_backup/**" },
        { "path": "$HOME/SkillSafe" },
        { "path": "$HOME/SkillSafe/**" },
        { "path": "$HOME/Library/LaunchAgents" },
        { "path": "$HOME/Library/LaunchAgents/**" },
        { "path": "$HOME/Library/Application Support/skillsafe-app" },
        { "path": "$HOME/Library/Application Support/skillsafe-app/**" },
        { "path": "$HOME/Library/Application Support/app.skillsafe.ai" },
        { "path": "$HOME/Library/Application Support/app.skillsafe.ai/**" },
        { "path": "$HOME/Library/Application Support/Claude" },
        { "path": "$HOME/Library/Application Support/Claude/**" },
        { "path": "$HOME/Library/Logs/skillsafe-backup.log" },
        { "path": "$HOME/Library/Logs/skillsafe-backup.log.old" },
        { "path": "$HOME/.local/share/skillsafe-app" },
        { "path": "$HOME/.local/share/skillsafe-app/**" },
        { "path": "$HOME/.local/state/skillsafe-app" },
        { "path": "$HOME/.local/state/skillsafe-app/**" },
        { "path": "$HOME/AppData/Local/skillsafe-app" },
        { "path": "$HOME/AppData/Local/skillsafe-app/**" },
        { "path": "$HOME/AppData/Local/app.skillsafe.ai" },
        { "path": "$HOME/AppData/Local/app.skillsafe.ai/**" },
        { "path": "$HOME/AppData/Roaming/app.skillsafe.ai" },
        { "path": "$HOME/AppData/Roaming/app.skillsafe.ai/**" },
        { "path": "$HOME/AppData/Roaming/Claude" },
        { "path": "$HOME/AppData/Roaming/Claude/**" },
        { "path": "$HOME/Library/CloudStorage" },
        { "path": "$HOME/Library/CloudStorage/**" },
        { "path": "$HOME/Library/Mobile Documents" },
        { "path": "$HOME/Library/Mobile Documents/**" },
        { "path": "$HOME/Documents" },
        { "path": "$HOME/Documents/**" },
        { "path": "$HOME/Desktop" },
        { "path": "$HOME/Desktop/**" },
        { "path": "$HOME/Downloads" },
        { "path": "$HOME/Downloads/**" },
        { "path": "$HOME/Dropbox" },
        { "path": "$HOME/Dropbox/**" },
        { "path": "$HOME/OneDrive" },
        { "path": "$HOME/OneDrive/**" },
        { "path": "$HOME/Google Drive" },
        { "path": "$HOME/Google Drive/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "launchctl", "cmd": "launchctl", "args": true },
        { "name": "id", "cmd": "id", "args": true },
        { "name": "plutil", "cmd": "plutil", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "powershell", "cmd": "powershell.exe", "args": true },
        { "name": "schtasks", "cmd": "schtasks.exe", "args": true },
        { "name": "crontab", "cmd": "crontab", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "launchctl", "cmd": "launchctl", "args": true },
        { "name": "id", "cmd": "id", "args": true },
        { "name": "plutil", "cmd": "plutil", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "powershell", "cmd": "powershell.exe", "args": true },
        { "name": "schtasks", "cmd": "schtasks.exe", "args": true },
        { "name": "crontab", "cmd": "crontab", "args": true }
      ]
    },
    "os:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.skillsafe.ai/*" },
        { "url": "https://app.skillsafe.ai/*" },
        { "url": "https://api.github.com/*" },
        { "url": "https://codeload.github.com/*" }
      ]
    },
    "updater:default",
    "process:default",
    "deep-link:default"
  ]
}
